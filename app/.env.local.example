# Claude Code Command Center — environment configuration
# Copy this file to .env.local and adjust as needed.
# Run: cp .env.local.example .env.local

# ── Project discovery ────────────────────────────────────────────────
# Directory (or comma-separated list) containing your projects.
# Auto-detected from: ~/Desktop, ~/Projects, ~/projects, ~/code, ~/dev, ~/workspace
# CLAUDE_CC_PROJECTS_DIR=~/Projects
# CLAUDE_CC_PROJECTS_DIR=~/work,~/personal   # multiple roots

# ── GitHub API ──────────────────────────────────────────────────────
# Personal Access Token for Discover search (avoids 60 req/hr rate limit).
# Create at: https://github.com/settings/tokens  (public_repo read scope)
# GITHUB_TOKEN=ghp_...

# ── AI Suggestions ──────────────────────────────────────────────────
# Anthropic API key to enable the "AI Suggest" tab in Discover.
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
